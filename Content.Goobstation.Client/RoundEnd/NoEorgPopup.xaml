<controls:FancyWindow xmlns="https://spacestation14.io"
                      xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls;assembly=Content.Client"
                      MinSize="500 280"
                      MaxSize="500 280">
    <BoxContainer Orientation="Vertical" Margin="10">
        <Label Name="TitleLabel"
               StyleClasses="LabelBig"
               HorizontalAlignment="Center"
               Margin="0 0 0 5" />
        <RichTextLabel Name="RuleLabel" HorizontalAlignment="Center"/>
        <PanelContainer StyleClasses="BackgroundDark" Margin="0 0 0 10">
            <BoxContainer Orientation="Vertical" Margin="10">
                <RichTextLabel Name="MessageLabel" HorizontalAlignment="Center" />
            </BoxContainer>
        </PanelContainer>
        <BoxContainer Orientation="Vertical" VerticalAlignment="Bottom" Margin="0 5 0 0">
            <Button Name="NoEorgCloseButton"
                    HorizontalAlignment="Center"
                    MinWidth="150" />
        </BoxContainer>
    </BoxContainer>
</controls:FancyWindow>
